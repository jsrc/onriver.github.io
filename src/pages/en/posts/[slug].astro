---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { copy } from "../../../data/site";
import { findTranslation, formatDate, getPostsByLocale, getPostUrl } from "../../../lib/blog";

export const getStaticPaths = (async () => {
  const posts = await getPostsByLocale("en");
  return posts.map((entry) => ({
    params: { slug: entry.data.pathSlug },
    props: { entry }
  }));
}) satisfies GetStaticPaths;

const locale = "en";
const { entry } = Astro.props;
const { Content } = await entry.render();
const translation = await findTranslation(entry);
---

<BaseLayout
  locale={locale}
  switchHref={translation ? getPostUrl(translation) : "/"}
  title={entry.data.title}
  description={entry.data.excerpt}
>
  <section class="subpage-hero post-hero" style={`--hero-image: url(${entry.data.heroImage});`}>
    <div class="subpage-hero-inner">
      <p class="hero-eyebrow">{formatDate(entry.data.publishDate, locale)}</p>
      <h1>{entry.data.title}</h1>
      {entry.data.subtitle && <p class="post-subtitle">{entry.data.subtitle}</p>}
    </div>
  </section>

  <section class="content-section post-layout">
    <article class="article-shell">
      <div class="article-meta">
        {entry.data.tags.map((tag) => <a href={`/en/tags/#${tag}`}>{tag}</a>)}
      </div>
      <div class="article-body">
        <Content />
      </div>
    </article>

    <aside class="article-aside">
      <p>{copy[locale].sections.archive}</p>
      <div class="tag-cloud">
        {entry.data.tags.map((tag) => <a href={`/en/tags/#${tag}`}>{tag}</a>)}
      </div>
      {translation && (
        <p>
          <a href={getPostUrl(translation)}>阅读中文版本</a>
        </p>
      )}
    </aside>
  </section>
</BaseLayout>
